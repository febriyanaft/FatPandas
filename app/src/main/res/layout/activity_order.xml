<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout android:id="@+id/topBar"
        android:layout_width="match_parent" android:layout_height="90dp"
        android:background="@color/bg_card" android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="27dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView android:id="@+id/btnBack"
            android:layout_width="28dp" android:layout_height="28dp"
            android:src="@drawable/ic_back" app:tint="@color/icon_tint"
            android:contentDescription="@string/content_desc_back"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="@string/title_order_menu"
            android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
        <View android:layout_width="28dp" android:layout_height="28dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="12dp" android:paddingBottom="12dp">

            <!-- ITEMS SUMMARY -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Ringkasan Pesanan"
                android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

            <!-- DATA PEMESAN -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/label_customer_data"
                android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>

            <!-- NAMA -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nama Lengkap" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" *" android:textSize="12sp" android:textColor="#FF0000" android:textStyle="bold"/>
                </LinearLayout>
                <EditText android:id="@+id/etNama"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_full_name"
                    android:textColorHint="@color/text_secondary" android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:importantForAutofill="yes"
                    android:autofillHints="name"/>
            </LinearLayout>

            <!-- PHONE -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="No. Telepon" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" *" android:textSize="12sp" android:textColor="#FF0000" android:textStyle="bold"/>
                </LinearLayout>
                <EditText android:id="@+id/etPhone"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_phone"
                    android:textColorHint="@color/text_secondary" android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="phone"
                    android:importantForAutofill="yes"
                    android:autofillHints="phoneDevice"/>
            </LinearLayout>

            <!-- MEJA -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No. Meja" android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginStart="4dp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etMeja"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_table_no"
                    android:textColorHint="@color/text_secondary" android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="text"
                    android:importantForAutofill="no"/>
            </LinearLayout>

            <!-- ORDER TYPE -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_order_type"
                android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgOrderType"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <RadioButton android:id="@+id/rbDineIn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/option_dine_in" android:checked="true"
                    android:textSize="14sp" android:textColor="@color/text_primary"/>
                <RadioButton android:id="@+id/rbTakeAway"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/option_take_away"
                    android:textSize="14sp" android:textColor="@color/text_primary"/>
            </RadioGroup>

            <!-- CATATAN -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/hint_notes" android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginStart="4dp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etCatatan"
                    android:layout_width="match_parent" android:layout_height="100dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_notes"
                    android:textColorHint="@color/text_secondary" android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:importantForAutofill="no"/>
            </LinearLayout>

            <!-- PAYMENT METHOD -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_payment_method"
                android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
            <RadioGroup android:id="@+id/rgPayment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="20dp">
                <RadioButton android:id="@+id/rbQRIS"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/option_qris" android:checked="true"
                    android:textSize="14sp" android:textColor="@color/text_primary"/>

                <RadioButton
                    android:id="@+id/rbCash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/option_cash"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM -->
    <LinearLayout android:id="@+id/bottomSection"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/bg_card" android:elevation="8dp"
        android:orientation="vertical" android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_total"
                android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/dummy_menu_price"
                android:textColor="@color/green" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>

        <Button android:id="@+id/btnLanjutKonfirmasi"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_continue_confirmation"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
            android:textAllCaps="false"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
